{
  "expo": {
    "name": "Tincadia",
    "slug": "tincadia",
    "scheme": "tincadia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "platforms": [
      "android",
      "ios"
    ],
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tincadia.app",
      "usesAppleSignIn": true,
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSContactsUsageDescription": "Tincadia necesita acceso a tus contactos para encontrar amigos que ya usan la app y facilitar la comunicación.",
        "NSLocationWhenInUseUsageDescription": "Tincadia necesita tu ubicación para enviar coordenadas precisas en caso de emergencia SOS.",
        "NSFaceIDUsageDescription": "Tincadia usa Face ID para iniciar sesión de forma rápida y segura.",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "remote-notification"
        ],
        "NSCameraUsageDescription": "Necesitamos acceso a tu cámara para videollamadas y enviar fotos.",
        "NSMicrophoneUsageDescription": "Necesitamos acceso a tu micrófono para llamadas de voz y mensajes de audio.",
        "NSPhotoLibraryUsageDescription": "Necesitamos acceso a tu galería para enviar imágenes y videos."
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "package": "com.tincadia.app",
      "usesCleartextTraffic": true,
      "versionCode": 6,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#ffffff",
      "androidMode": "default"
    },
    "plugins": [
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.291627235984-al9qlsj9slos34mh9uca410q89oq7jl5"
        }
      ],
      [
        "@react-native-firebase/app",
        {
          "android": {
            "firebaseBomVersion": "32.8.1"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Tincadia necesita acceso a tu galería para cambiar tu foto de perfil.",
          "cameraPermission": "Tincadia necesita acceso a tu cámara para tomar fotos de perfil."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Necesitamos acceso a tu cámara para escanear códigos QR."
        }
      ],
      [
        "expo-web-browser",
        {}
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Tincadia necesita acceso a tus contactos para encontrar amigos que ya usan la app."
        }
      ],
      "expo-sqlite",
      "./plugins/withModularHeaders",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "univalle-gi"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Tincadia utiliza esta información para evaluar el rendimiento, analizar el uso y proveer de soporte técnico especializado, con el fin de mejorar tu experiencia en la aplicación."
        }
      ],
      "./plugins/withPictureInPicture"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "8bf6b071-622c-4428-a2f8-b83b95fa2d99"
      }
    }
  }
}